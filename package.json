{
  "name": "nodejs-app-analyzer",
  "version": "1.0.1",
  "description": "Comprehensive NodeJS application performance, security, and quality analyzer",
  "main": "dist/cli.js",
  "bin": {
    "nodejs-app-analyzer": "./dist/cli.js",
    "node-analyze": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "start": "node dist/cli.js",
    "dev": "tsup && node dist/cli.js",
    "test": "jest",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "nodejs",
    "analyzer",
    "security",
    "performance",
    "quality",
    "scaling",
    "code-quality",
    "static-analysis",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.0.0",
    "complexity-report": "^2.0.0-alpha",
    "eslint": "^8.50.0",
    "eslint-plugin-security": "^1.7.1",
    "fs-extra": "^11.1.1",
    "glob": "^10.3.10",
    "madge": "^6.1.0",
    "npm-audit-resolver": "^3.0.0-RC.0",
    "ora": "^5.4.1",
    "table": "^6.8.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.3.0"
  }
}
